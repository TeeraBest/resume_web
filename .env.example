# Production environment variables
# Copy to .env and update values before running docker compose

POSTGRES_USER=resume_user
POSTGRES_PASSWORD=resume_pass
POSTGRES_DB=resume_db
DATABASE_URL=postgresql://resume_user:resume_pass@postgres:5432/resume_db
VALKEY_PORT=6379
CACHE_TTL=300
VITE_API_BASE_URL=https://example.com/api/v1
